{
  "redirects": [
    {
      "source": "/mwitch.zip",
      "destination": "https://github.com/viraatdas/mwitch/releases/latest/download/mwitch.zip",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/appcast.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/logo.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
